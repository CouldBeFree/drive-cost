# Database
# For local PostgreSQL installation
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/drivecost

# For Docker container (recommended for development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/drivecost

# Auth
# Generate a random secret for session encryption
# You can generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=change-this-to-a-random-secret-at-least-32-characters-long
