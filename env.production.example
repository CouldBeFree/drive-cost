# =============================================================================
# DriveCost Production Environment Variables
# =============================================================================

# Environment
ENVIRONMENT=production

# Database Configuration
POSTGRES_DB=drivecost
POSTGRES_USER=drivecost_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5433
DATABASE_URL=postgresql://drivecost_user:your_secure_password_here@postgres:5432/drivecost

# Application Configuration
APP_PORT=3000
NODE_ENV=production

# Nuxt Auth (generate with: openssl rand -base64 32)
NUXT_SESSION_PASSWORD=your_32_character_session_password_here

# Grafana Configuration
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here
GRAFANA_ROOT_URL=http://localhost:3001
